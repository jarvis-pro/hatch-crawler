# 复制为 .env（本地开发 + docker compose 都读这一个文件）：
#
#   cp .env.example .env
#
# Next.js 读取优先级：.env.local > .env.development > .env
# docker compose 默认读取项目根目录的 .env（不读 .env.local）
#
# 下面把"本地直跑 pnpm dev"和"docker compose up"两套变量合并在一份里，
# 它们互不冲突——Next.js 直接消费 DATABASE_URL；
# compose 只挑 POSTGRES_* 三件套和 LOG_LEVEL 来插值，
# 在 web 容器里把 DATABASE_URL 重新拼成 host=postgres（容器名）。

# ──── 本地 pnpm dev 用 ────────────────────────────────────
# Postgres 连接串，host 用 localhost 指本机（或 docker compose 暴露在
# 127.0.0.1:5432 的 postgres 服务）。换本机已有 Postgres 时改这里。
DATABASE_URL=postgres://hatch:hatch@localhost:5432/hatch

# ──── docker compose 用 ──────────────────────────────────
# postgres 镜像的官方约定变量，用来初始化数据库；
# compose 同时用这三个值在 web 容器内拼出 DATABASE_URL（host=postgres）。
# 只本地跑 pnpm dev 时这三行可以删，留着也无害。
POSTGRES_DB=hatch
POSTGRES_USER=hatch
POSTGRES_PASSWORD=hatch

# ──── 两边都用 ───────────────────────────────────────────
# pino 日志级别：trace / debug / info / warn / error
LOG_LEVEL=info
