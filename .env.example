# ==== 爬虫基础设置 ====

# 日志级别：trace / debug / info / warn / error
LOG_LEVEL=info

# 全局并发：同时在飞的请求数
CONCURRENCY=4

# 单一域名的最小请求间隔（毫秒），用于"礼貌爬取"，避免被同源限流
PER_HOST_INTERVAL_MS=500

# 单次请求的默认超时时间（毫秒）
REQUEST_TIMEOUT_MS=15000

# 临时性失败（5xx / 429 / 网络错误）的重试次数
RETRY_ATTEMPTS=3

# ==== 存储 ====

# SQLite 数据库文件路径（结构化存储 + 增量去重）
SQLITE_PATH=./data/crawler.sqlite

# JSON Lines 文件路径（追加写入，方便 jq / pandas 后处理）
JSONL_PATH=./data/items.jsonl

# ==== 代理池（可选）====

# 多个代理用英文逗号分隔，例如：http://user:pass@host:port,http://...
# 留空则直连，不走代理
PROXY_LIST=

# ==== 调度 ====

# Cron 表达式，用于周期性重抓，例如 "*/30 * * * *" 表示每 30 分钟一次
# 留空则只跑一次（一次性运行模式）
CRON_SCHEDULE=
