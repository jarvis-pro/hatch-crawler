# 复制为 .env.local（本地开发）或 .env（Docker 部署）：
#
#   cp .env.example .env.local
#
# Next.js 自动读取的优先级：.env.local > .env.development > .env
# 详见 https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# ──── 数据库 ─────────────────────────────────────────────
# Postgres 连接串。本地用 docker compose 起的是 hatch:hatch；
# 如果你用本机已有的 Postgres，改成对应的用户/密码/库名。
DATABASE_URL=postgres://hatch:hatch@localhost:5432/hatch

# ──── 日志 ───────────────────────────────────────────────
# pino 日志级别：trace / debug / info / warn / error
LOG_LEVEL=info
