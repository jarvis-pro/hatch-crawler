# Docker Compose 部署用的环境变量。
# 复制为 .env 即可（compose 会自动读取根目录的 .env 文件）。
#
#   cp .env.docker.example .env

# ──── Postgres ────────────────────────────────────────────
POSTGRES_DB=hatch
POSTGRES_USER=hatch
POSTGRES_PASSWORD=hatch

# ──── apps/web ────────────────────────────────────────────
# pino 日志级别：trace / debug / info / warn / error
LOG_LEVEL=info
