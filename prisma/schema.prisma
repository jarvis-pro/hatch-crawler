// Prisma schema —— 与 docs/reference/data-model.md 一一对应。修改前先读那份文档。
//
// 命名约定：
//   - 表名 / 列名用 snake_case（@@map / @map）
//   - 索引名用 idx_<table>_<cols>，唯一索引用 uniq_<...>

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────
// 枚举
// ──────────────────────────────────────────────────────────

enum RunStatus {
  queued
  running
  completed
  failed
  stopped

  @@map("run_status")
}

enum EventLevel {
  debug
  info
  warn
  error

  @@map("event_level")
}

// ──────────────────────────────────────────────────────────
// spiders —— 注册的 Spider 定义
// ──────────────────────────────────────────────────────────

model Spider {
  /// UUID 主键，由数据库自动生成
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 用户自定义显示名称（中文友好，如 "YouTube 搜索 - 健身"），可重复
  name                String   @db.VarChar(128)
  /// 注册表类型键（如 "youtube-channel-videos"），worker 靠此反查实现类
  type                String   @db.VarChar(64)
  description         String?
  startUrls           Json     @map("start_urls")
  allowedHosts        Json     @default("[]") @map("allowed_hosts")
  maxDepth            Int      @default(2) @map("max_depth")
  concurrency         Int      @default(4)
  perHostIntervalMs   Int      @default(500) @map("per_host_interval_ms")
  enabled             Boolean  @default(true)
  cronSchedule        String?  @map("cron_schedule") @db.VarChar(64)
  // Phase 5：多平台标记
  platform            String?  @db.VarChar(32)
  emitsKinds          Json     @default("[]") @map("emits_kinds")
  // Phase A：Spider 运行时参数默认值（channelId / query 等）
  defaultParams       Json     @default("{}") @map("default_params")
  // RFC 0003：任务类型派生标记（subscription / batch / extract）
  taskKind            String   @map("task_kind") @db.VarChar(16)
  // Phase X：连续失败计数，超阈值自动停用
  consecutiveFailures Int      @default(0) @map("consecutive_failures")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime @default(now()) @map("updated_at") @db.Timestamp(6)

  runs Run[]

  @@index([taskKind], map: "idx_spiders_task_kind")
  @@map("spiders")
}

// ──────────────────────────────────────────────────────────
// runs —— 每次抓取实例
// ──────────────────────────────────────────────────────────

model Run {
  id          String    @id @default(uuid()) @db.Uuid
  spiderName  String    @map("spider_name") @db.VarChar(128)
  /// FK 引用 spiders.id，nullable 兼容历史数据
  spiderId    String?   @map("spider_id") @db.Uuid
  status      RunStatus @default(queued)
  triggerType String    @map("trigger_type") @db.VarChar(16)
  overrides   Json?     @default("{}")
  // RFC 0003：从 spider.task_kind 同步写入，查询时免 JOIN
  taskKind    String?   @map("task_kind") @db.VarChar(16)

  // 统计字段，worker 增量更新
  fetched  Int @default(0)
  emitted  Int @default(0)
  newItems Int @default(0) @map("new_items")
  errors   Int @default(0)

  startedAt    DateTime? @map("started_at") @db.Timestamp(6)
  finishedAt   DateTime? @map("finished_at") @db.Timestamp(6)
  errorMessage String?   @map("error_message")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  spider Spider? @relation(fields: [spiderId], references: [id], onDelete: Cascade)
  events Event[]
  items  Item[]

  @@index([status], map: "idx_runs_status")
  @@index([spiderName, createdAt], map: "idx_runs_spider")
  @@index([spiderId], map: "idx_runs_spider_id")
  @@map("runs")
}

// ──────────────────────────────────────────────────────────
// events —— Run 的事件流（持久化日志）
// ──────────────────────────────────────────────────────────

model Event {
  id         Int        @id @default(autoincrement())
  runId      String     @map("run_id") @db.Uuid
  level      EventLevel
  type       String     @db.VarChar(32)
  message    String?
  payload    Json?      @default("{}")
  occurredAt DateTime   @default(now()) @map("occurred_at") @db.Timestamp(6)

  run Run @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, occurredAt], map: "idx_events_run_time")
  @@map("events")
}

// ──────────────────────────────────────────────────────────
// items —— 抓取到的内容
// ──────────────────────────────────────────────────────────

model Item {
  /// UUID 主键。改用 uuid 是为了不通过自增数泄漏内容总量；
  /// 历史 serial 列已通过迁移替换为 uuid，原 id 不再保留。
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  runId        String?  @map("run_id") @db.Uuid
  spider       String   @db.VarChar(64)
  type         String   @db.VarChar(32)
  url          String
  urlHash      String   @map("url_hash") @db.Char(40)
  contentHash  String   @map("content_hash") @db.Char(40)
  payload      Json
  fetchedAt    DateTime @default(now()) @map("fetched_at") @db.Timestamp(6)
  // Phase 5：多平台标记
  platform     String?  @db.VarChar(32)
  kind         String?  @db.VarChar(16)
  sourceId     String?  @map("source_id") @db.VarChar(128)
  // RFC 0003：来源 chip 过滤用
  triggerKind  String?  @map("trigger_kind") @db.VarChar(16)
  taskId       String?  @map("task_id") @db.Uuid
  // 快取（extract）链路：当 item 来自 /api/extract 时回填 extract_jobs.id
  // 与 runId 互斥：extract 不再走 runs，extract_job_id 非空时 run_id=null
  extractJobId String?  @map("extract_job_id") @db.Uuid

  run        Run?        @relation(fields: [runId], references: [id], onDelete: SetNull)
  extractJob ExtractJob? @relation(fields: [extractJobId], references: [id], onDelete: SetNull)

  @@unique([spider, urlHash, contentHash], map: "uniq_items_spider_url_content")
  @@index([spider, type], map: "idx_items_spider_type")
  @@index([fetchedAt], map: "idx_items_fetched_at")
  @@index([kind], map: "idx_items_kind")
  @@index([platform], map: "idx_items_platform")
  @@index([triggerKind], map: "idx_items_trigger_kind")
  @@index([extractJobId], map: "idx_items_extract_job_id")
  @@map("items")
}

// ──────────────────────────────────────────────────────────
// extract_jobs —— 快取（按链接抓取）任务
// ──────────────────────────────────────────────────────────
//
// 与 runs 解耦：URL 驱动的快取走自己的轻量任务表，不再借用 spider/run。
// 一条 extract_job 对应用户一次提交的 URL 批次：
//   - submittedUrls：用户原始输入（含 invalid / unsupported，留作审计）
//   - results：每条 supported URL 的处理状态 map（key = canonicalUrl）
//   - succeeded / failed：聚合计数；total = len(results)
//   - status：running 入队即置；completed 当 succeeded+failed=total
//
// 失败原因 / 命中的 platform / 关联 item id 都写在 results jsonb 内部，
// 不再依赖 events 表。

model ExtractJob {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 用户原始提交的 URL 字符串数组（含被拒绝项），仅作审计
  submittedUrls Json      @default("[]") @map("submitted_urls")
  /// 每条 canonical URL 的状态 map：
  /// { [canonicalUrl]: { originalUrl, platform, status, errorCode?, errorMessage?, itemId?, finishedAt? } }
  results       Json      @default("{}")
  total         Int       @default(0)
  succeeded     Int       @default(0)
  failed        Int       @default(0)
  status        String    @default("running") @db.VarChar(16)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  finishedAt    DateTime? @map("finished_at") @db.Timestamp(6)

  items Item[]

  @@index([createdAt], map: "idx_extract_jobs_created_at")
  @@index([status], map: "idx_extract_jobs_status")
  @@map("extract_jobs")
}

// ──────────────────────────────────────────────────────────
// accounts —— 平台凭据（Phase 6）
// ──────────────────────────────────────────────────────────

enum AccountKind {
  cookie
  oauth
  apikey
  session

  @@map("account_kind")
}

enum AccountStatus {
  active
  expired
  banned
  disabled

  @@map("account_status")
}

model Account {
  id             Int           @id @default(autoincrement())
  platform       String        @db.VarChar(32)
  label          String        @db.VarChar(64)
  kind           AccountKind
  payloadEnc     String        @map("payload_enc") @db.Text
  expiresAt      DateTime?     @map("expires_at") @db.Timestamp(6)
  status         AccountStatus @default(active)
  lastUsedAt     DateTime?     @map("last_used_at") @db.Timestamp(6)
  failureCount   Int           @default(0) @map("failure_count")
  // Phase D：健康度监控
  lastTestedAt   DateTime?     @map("last_tested_at") @db.Timestamp(6)
  lastTestOk     Boolean?      @map("last_test_ok")
  quotaUsedToday Int           @default(0) @map("quota_used_today")
  quotaResetAt   DateTime      @default(now()) @map("quota_reset_at") @db.Date
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime      @default(now()) @map("updated_at") @db.Timestamp(6)

  @@index([platform, status], map: "idx_accounts_platform_status")
  @@map("accounts")
}

// ──────────────────────────────────────────────────────────
// webhook_deliveries —— Webhook 投递记录（RFC 0003 阶段二）
// ──────────────────────────────────────────────────────────

model WebhookDelivery {
  id          Int       @id @default(autoincrement())
  eventType   String    @map("event_type") @db.VarChar(64)
  payload     Json
  url         String    @db.Text
  status      String    @default("pending") @db.VarChar(16)
  attempts    Int       @default(0)
  lastStatus  Int?      @map("last_status")
  lastError   String?   @map("last_error") @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  deliveredAt DateTime? @map("delivered_at") @db.Timestamp(6)

  @@index([status], map: "idx_webhook_deliveries_status")
  @@index([createdAt], map: "idx_webhook_deliveries_created_at")
  @@map("webhook_deliveries")
}

// ──────────────────────────────────────────────────────────
// settings —— 通用 KV
// ──────────────────────────────────────────────────────────

model Setting {
  key       String   @id @db.VarChar(64)
  value     Json
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamp(6)

  @@map("settings")
}
